# --- 依赖目录 ---
node_modules/
jspm_packages/

# --- 构建产物 (根据你使用的框架取消注释) ---
dist/
build/
.next/
.nuxt/
out/

# --- 日志文件 ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- 环境配置文件 (包含 API Key 等敏感信息) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- 编辑器/系统配置文件 ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# --- 测试与覆盖率 ---
coverage/
.nyc_output

# --- 缓存 ---
.cache/
.eslintcache
.stylelintcache